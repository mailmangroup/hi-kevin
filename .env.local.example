# KAWO Kevin Frontend Environment Variables

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mock Mode (Optional)
# Set to 'true' to use mock data instead of real API calls
# NEXT_PUBLIC_USE_MOCK=false

# KAWO credentials for local development (Required when mock mode is disabled)
# Development reads these values from `.env.local`; production ignores them and
# reads the signed-in user's `user_kawo_credentials` row from Supabase instead.
# Do not configure these variables in Vercel.
# NEXT_PUBLIC_KAWO_TOKEN=your_kawo_token
# NEXT_PUBLIC_KAWO_ORG_ID=your_kawo_org_id
# NEXT_PUBLIC_KAWO_BRAND_ID=your_kawo_brand_id
# API URL is optional and defaults to DEFAULT_KAWO_API_URL when omitted.
# NEXT_PUBLIC_KAWO_API_URL=http://localhost:8005

# Dev user display name (Optional, defaults to 'Developer')
# NEXT_PUBLIC_DEV_USER_NAME=YourName
# NEXT_PUBLIC_DEV_USER_EMAIL=you@example.com
