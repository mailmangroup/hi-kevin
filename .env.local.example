# KAWO Kevin Frontend Environment Variables

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Local Development Overrides (Optional)
# Set these to bypass database stored credentials for local testing
# Only effective when NODE_ENV=development
# KAWO_TOKEN=your_kawo_token
# KAWO_ORG_ID=your_kawo_org_id
# KAWO_BRAND_ID=your_kawo_brand_id
# KAWO_API_URL=http://localhost:8005
